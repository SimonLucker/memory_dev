# AI guide for Memorialization (Azure OpenAI for now; swappable to Claude later)
AZURE_OPENAI_ENDPOINT=https://retailaipocpeo.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=preview
AZURE_OPENAI_API_KEY=

# Speech-to-text for voice memories
DEEPGRAM_API_KEY=

# Supabase (deployed mode). When BOTH are set the app talks to Supabase
# (Postgres + Storage + Edge Functions) instead of the local dev endpoints.
# Also set these two on Vercel (Project → Settings → Environment Variables).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
